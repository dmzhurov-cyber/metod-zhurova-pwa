# Скопируйте в .env.local для локальной разработки.
# В Netlify: Site settings → Environment variables.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OpenAI — для AI-тренера (Джаан).
# ВАЖНО: для продакшена перенести в Supabase Edge Function, чтобы ключ не был виден в браузере.
VITE_OPENAI_API_KEY=

# Максимальный открытый день курса (1–30). Пусто или 30 = все дни. Для продажи первой недели: 7 (или 10).
# VITE_MAX_UNLOCKED_DAY=7
